{
  "name": "@voltiso/script",
  "version": "3.0.0",
  "license": "MIT",
  "repository": "git://github.com/voltiso/mono.git",
  "__________": "__________",
  "type": "module",
  "sideEffects": false,
  "__________EXECUTABLES": "__________",
  "bin": {
    "v": "dist/cjs/bin/v.js",
    "voltiso": "dist/cjs/bin/v.js"
  },
  "__________EXPORTS": "__________",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/esm/index.d.ts",
        "require": "./dist/cjs/index.d.ts"
      },
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./bin": {
      "types": {
        "import": "./dist/esm/bin/v.d.ts",
        "require": "./dist/cjs/bin/v.d.ts"
      },
      "import": "./dist/esm/bin/v.js",
      "require": "./dist/cjs/bin/v.js"
    }
  },
  "typesVersions": {
    "*": {
      "bin": [
        "dist/cjs/bin"
      ]
    }
  },
  "__________EXPORTS FALLBACK": "__________",
  "types": "dist/cjs/index.d.ts",
  "module": "dist/esm/index.js",
  "main": "dist/cjs/index.js",
  "__________PUBLISH WHITELIST": "__________",
  "files": [
    "dist",
    "bin/"
  ],
  "__________SCRIPTS": "__________",
  "scripts": {
    "__________TURBO": "__________",
    "build": "pnpm run \"/^build:(esm|cjs)$/\" && pnpm exec v compatDirs write",
    "check": "v check",
    "__________HOOKS": "__________",
    "prepublishOnly": "v prepublishOnly",
    "__________IMPL": "__________",
    "build:esm": "pnpm run build:esm:clean && pnpm run build:esm:tsc && pnpm run build:esm:type",
    "build:esm:clean": "rimraf dist/esm",
    "build:esm:tsc": "tspc -b tsconfig.build.esm.json",
    "build:esm:type": "echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:cjs": "pnpm run build:cjs:clean && pnpm run build:cjs:tsc && pnpm run build:cjs:type",
    "build:cjs:clean": "rimraf dist/cjs",
    "build:cjs:tsc": "tspc -b tsconfig.build.cjs.json",
    "build:cjs:type": "echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json"
  },
  "__________DEPS": "__________",
  "dependencies": {
    "@voltiso/util.node": "workspace:^",
    "esbuild": "^0.27.3",
    "esbuild-register": "^3.5.0",
    "picocolors": "^1.1.1",
    "pidtree": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@voltiso/transform": "workspace:^"
  },
  "__________MISC": "__________",
  "engines": {
    "node": ">= 18"
  }
}
