#pragma once
#include <v/_/_>

#include "v/size"
#include "v/trait/num-items"

#include <type_traits>

#include <v/ON>

namespace V::get::_ {
template <class T> [[nodiscard]] static constexpr auto dynamic_num_items(const T &t) noexcept {
	if constexpr (requires { t.numItems(); }) {
		static_assert(noexcept(t.numItems()));
		return t.numItems();
	} else if constexpr (requires { t.size(); }) {
		static_assert(noexcept(t.size()));
		return t.size();
	} else if constexpr (!std::is_void_v<decltype(trait::numItems<T>)>) {
		return trait::numItems<T>;
	} else {
		return; // void
	}
}
} // namespace V::get::_

namespace V::get {
template <class T>
  requires(!std::is_void_v<decltype(_::dynamic_num_items(std::declval<T>()))>)
[[nodiscard]] static constexpr Size numItems(const T &t) noexcept {
	return _::dynamic_num_items(t);
}
} // namespace V::get

#include <v/OFF>
