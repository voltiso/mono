#pragma once
#include <v/_/_>

namespace VOLTISO_NAMESPACE::mixin {

/// Mixin that adds a user-defined copy constructor so the derived type is not
/// trivially copyable and is not automatically marked trivially relocatable
/// by the compiler.
struct NonRelocatable {
	NonRelocatable() = default;
	NonRelocatable(const NonRelocatable &) {}
};

} // namespace VOLTISO_NAMESPACE::mixin
