	// 			std::memcpy(_items(), other.items(), sizeof(Item) * NUM_ITEMS);
	// 		} else {
	// 			std::copy(other.items(), other.items() + Other::NUM_ITEMS, _items());
	// 		}
	// 		return _final();
	// 	}

