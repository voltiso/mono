{
	"version": 8,
	"configurePresets": [
		{
			"name": "clang-22_Release",
			"inherits": "clang-22",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "clang-22_Debug",
			"inherits": "clang-22",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "clang-22_RelWithDebInfo",
			"inherits": "clang-22",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo"
			}
		},
		{
			"name": "clang-22",
			"hidden": true,
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "x64-linux-llvm",
				"VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg-triplets",
				"CMAKE_CXX_COMPILER": "/usr/bin/clang++-22",
				"CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld-22",
				"CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=lld-22",
				"CMAKE_EXPORT_COMPILE_COMMANDS": true
			}
		}
	],

	"buildPresets": [
		{
			"name": "clang-22_Release",
			"configurePreset": "clang-22_Release"
		},
		{
			"name": "clang-22_Debug",
			"configurePreset": "clang-22_Debug"
		},
		{
			"name": "clang-22_RelWithDebInfo",
			"configurePreset": "clang-22_RelWithDebInfo"
		}
	]
}
