#include "v/tensor"
#include "v/type-option"

#include <v/ON>

namespace VOLTISO_NAMESPACE::option {
namespace tensor {
template <template <class, auto... EXTENTS> class TTensor> struct Use {
	template <class Item, auto... EXTENTS>
	using Tensor = TTensor<Item, EXTENTS...>;
};
} // namespace tensor

/** We don't natively support template-template options different than
 * `class...`. Workaround: wrap custom template - see `option::tensor::Use`
 * default above. */
template <class TWrappedTensor>
struct Tensor : TypeOption<TWrappedTensor, tensor::Use<V::Tensor>> {};
} // namespace VOLTISO_NAMESPACE::option

#include <v/OFF>
