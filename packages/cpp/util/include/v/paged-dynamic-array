// ========================================================================
// THE CORE IMPLEMENTATION
// ========================================================================
namespace VOLTISO_NAMESPACE::pagedDynamicArray {

template <class Options>
  requires concepts::Options<Options>
class RELOCATABLE(Custom)
    : public Object<typename Options::template WithDefault<
        option::relocatable<true>,
        option::CustomTemplate<pagedDynamicArray::GetCustom>,
        option::InputOptions<Options>>> {
private:
	using Base = Object<typename Options::template WithDefault<
	  option::relocatable<true>,
	  option::CustomTemplate<pagedDynamicArray::GetCustom>,
	  option::InputOptions<Options>>>;

public:
	using Item = Options::template Get<option::Item>;
	// using Pool = Options::template Get<option::Pool>;
	static constexpr Size PAGE_SIZE = Options::template GET<option::PAGE_SIZE>;
	static constexpr bool COPY_ON_WRITE =
	  Options::template GET<option::COPY_ON_WRITE>;

	static_assert(PAGE_SIZE > 0, "PAGE_SIZE must be greater than 0");

	static_assert(
	  std::has_single_bit(static_cast<uint64_t>(PAGE_SIZE)),
	  "PAGE_SIZE must be a power of 2");

private:
	// If trivially copyable, we construct items directly. Constructors for
	// non-existing items are called immediately for performance (possible
	// vectorization).
	static constexpr bool WRAP_IN_STORAGE = !std::is_trivially_copyable_v<Item>;
	using ItemOrStorage =
	  std::conditional_t<WRAP_IN_STORAGE, Storage<Item>, Item>;

	template <Size NUM_ITEMS_PER_PAGE>
	using _Slots = Options::template Get<option::Tensor>::template Tensor<
	  ItemOrStorage, NUM_ITEMS_PER_PAGE>;

	template <Size NUM_ITEMS_PER_PAGE>
	struct alignas(COPY_ON_WRITE ? 0 : PAGE_SIZE) _PageBody {
		_Slots<NUM_ITEMS_PER_PAGE> slots;

		_PageBody() = default;

		// page does not know which elements are alive
		_PageBody(const _PageBody &) = delete;
		_PageBody &operator=(const _PageBody &) = delete;
	};

	template <Size NUM_ITEMS_PER_PAGE>
	using _Shared =
	  Shared<_PageBody<NUM_ITEMS_PER_PAGE>>::template WithAlign<PAGE_SIZE>;

	template <Size NUM_ITEMS_PER_PAGE>
	using _Page = std::conditional_t<
	  COPY_ON_WRITE, typename _Shared<NUM_ITEMS_PER_PAGE>::ControlBlock,
	  _PageBody<NUM_ITEMS_PER_PAGE>>;

	template <Size CAND = PAGE_SIZE / sizeof(Item)>
	static constexpr auto _findNumItemsPerPage() {
		// return CAND;

		// faster to compile
		struct FakePage {
			_Slots<CAND> slots;
			[[no_unique_address]] std::conditional_t<COPY_ON_WRITE, Size, Empty>
			  numReferences;
		};

		if constexpr (sizeof(FakePage) <= PAGE_SIZE) {
			return CAND;
		} else {
			return _findNumItemsPerPage<CAND - 1>();
		}

		// ! slower to compile
		// using Page = _Page<CAND>;
		// if constexpr (sizeof(Page) <= PAGE_SIZE) {
		// 	return CAND;
		// } else {
		// 	return _findNumItemsPerPage<CAND - 1>();
		// }
	}

public:
	static constexpr Size NUM_ITEMS_PER_PAGE = _findNumItemsPerPage<>();
	// static constexpr Size NUM_ITEMS_PER_PAGE = PAGE_SIZE / sizeof(Item);
	static_assert(
	  NUM_ITEMS_PER_PAGE > 0, "NUM_ITEMS_PER_PAGE must be greater than 0");

public:
	using Handle =
	  Handle::WithBrand<GetCustom<Options>>::template WithKind<Index>;

private:
	using PageBody = _PageBody<NUM_ITEMS_PER_PAGE>;
	using Page = _Page<NUM_ITEMS_PER_PAGE>;
	using Shared = _Shared<NUM_ITEMS_PER_PAGE>;
	using Slots = _Slots<NUM_ITEMS_PER_PAGE>;
	using Owned = Owned<PageBody>;

	static_assert(sizeof(Page) == PAGE_SIZE);
	static_assert(alignof(Page) == PAGE_SIZE);

	using Reference = std::conditional_t<COPY_ON_WRITE, Shared, Owned>;

	using Pages = DynamicArray<Reference>;

	// All members here
private:
	Size _numItems = 0;
	Pages _pages;

	// ! we're using static shared pool - easier to support snapshotting
	// ! (copy-on-write)
	// Pool _pool;

private:
	template <class... Args>
	INLINE void _constructItem(Slots &dst, Index idx, Args &&...args) {
		if constexpr (requires {
			              { dst[idx] } -> std::same_as<Item &>;
		              }) {
			static_assert(std::is_trivially_copyable_v<Item>);
			new (&dst[idx]) Item(std::forward<Args>(args)...);
		} else if constexpr (requires {
			                     { dst[idx] } -> std::same_as<Storage<Item> &>;
		                     }) {
			// dst[idx].construct(std::forward<Args>(args)...);
			new (&dst[idx]) Item(std::forward<Args>(args)...);
		} else if constexpr (requires { dst(idx); }) {
			static_assert(std::is_trivially_copyable_v<Item>);
			dst(idx) = Item{std::forward<Args>(args)...};
		} else {
			static_assert(false, "how do we construct item here?");
		}
	}

	INLINE void _copyItem(Slots &dst, const Slots &src, Index idx) {
		if constexpr (requires {
			              { src[idx] } -> std::same_as<const ItemOrStorage &>;
		              }) {
			dst[idx] = src[idx];
		} else if constexpr (requires { src(idx); }) {
			dst(idx) = src(idx);
		} else {
			static_assert(false, "how do we copy item here?");
		}
	}

private:
	// Copy-On-Write helper
	VOLTISO_FORCE_INLINE auto &_getPageForWrite(Index pageIdx) {
		auto &pageRef = _pages[pageIdx];
		if constexpr (COPY_ON_WRITE) {
			if (pageRef.numReferences() > 1) [[unlikely]] {
				auto newPage = Shared::create();
				auto numItemsInPage = _numItems - pageIdx * NUM_ITEMS_PER_PAGE;
				if (numItemsInPage > NUM_ITEMS_PER_PAGE) [[likely]] {
					numItemsInPage = NUM_ITEMS_PER_PAGE;
				}
				for (Index i = 0; i < numItemsInPage; ++i) {
					_copyItem(newPage->slots, pageRef->slots, i);
				}
				pageRef = std::move(newPage);
			}
		}
		return pageRef;
	}

public:
	~Custom() noexcept = default;
	~Custom() noexcept(std::is_nothrow_destructible_v<Item>)
	  requires(!std::is_trivially_destructible_v<Item>)
	{
		for (Index i = 0; i < _pages.numItems() - 1; ++i) {
			for (auto &slot : _pages[i]->slots) {
				slot.destroy();
			}
		}
		// likely/unlikely? depends. let compiler inline and decide
		if (_pages.numItems() > 0) {
			auto &lastPage = _pages.last();
			auto numItemsInLastPage =
			  _numItems - (_pages.numItems() - 1) * NUM_ITEMS_PER_PAGE;
			for (Index i = 0; i < numItemsInLastPage; ++i) {
				lastPage->slots[i].destroy();
			}
		}
	}

public:
	Custom() noexcept = default;

	/** Implicit copy disabled. Use `.copy()` instead. */
	Custom(const Custom &) = delete;

	/** Explicit copy (this is not a move) */
	Custom(const Custom &&other)
	  requires(COPY_ON_WRITE)
	    : Base(other), _numItems(other._numItems), _pages(other._pages.copy()) {}

	/** Explicit copy (this is not a move) */
	Custom(const Custom &&other)
	  requires(!COPY_ON_WRITE)
	    : Base(other), _numItems(other._numItems) {
		auto numPages = other._pages.numItems();
		_pages.setNumSlotsAtLeast(numPages);
		for (Size i = 0; i < numPages; ++i) {
			_pages.pushUnchecked(Reference::create());
			_pages.last()->slots = other._pages[i]->slots.copy();
		}
	}

	// auto copy() requires (!COPY_ON_WRITE) = delete;

	// ========================================================================
	// ACCESSORS (The Hot Path)
	// ========================================================================

	[[nodiscard]] INLINE constexpr Size numItems() const noexcept {
		return _numItems;
	}

	[[nodiscard]] INLINE constexpr Size numPages() const noexcept {
		return _pages.numItems();
	}

	/** Only const operator[] to avoid CoW. If you need to write, use operator()
	 * to get an Accessor. */
	INLINE decltype(auto) operator[](const Index &i) const {
		GE(i, 0);
		LT(i, _numItems);
		Index pageIdx = i / NUM_ITEMS_PER_PAGE;
		Index offset = i % NUM_ITEMS_PER_PAGE;
		auto &slots = _pages[pageIdx]->slots;
		if constexpr (WRAP_IN_STORAGE) {
			return slots[offset].storedItem();
		} else {
			// can return accessor (proxy/view)
			return slots[offset];
		}
	}

	// ========================================================================
	// MODIFIERS
	// ========================================================================

	Handle pushUnchecked(Item &&item) { return push<>(std::move(item)); }
	Handle pushUnchecked(const Item &item) { return push<>(item); }

	/** ⚠️ Unchecked - does not grow the array */
	template <class... Args> Handle pushUnchecked(Args &&...args) {
		auto index = _numItems;
		auto pageIdx = index / NUM_ITEMS_PER_PAGE;
		auto offset = index % NUM_ITEMS_PER_PAGE;

		LT(pageIdx, _pages.numItems());

		auto &pageRef = _getPageForWrite(pageIdx);

		_constructItem(pageRef->slots, offset, std::forward<Args>(args)...);

		++_numItems;
		return Handle{index};
	}

	template <class... Args> Handle maybeGrowAndPush(Args &&...args) {
		LE(_numItems, _pages.numItems() * NUM_ITEMS_PER_PAGE);
		if (_numItems == _pages.numItems() * NUM_ITEMS_PER_PAGE) [[unlikely]] {
			_pages.maybeGrowAndPush(Reference::create());
		}
		return pushUnchecked<>(std::forward<Args>(args)...);
	}

	/** Does not shrink automatically. You may want to call `.maybeShrink()`
	 * afterwards. */
	Item pop() noexcept {
		GT(_numItems, 0);
		auto lastIndex = _numItems - 1;

		auto pageIdx = lastIndex / NUM_ITEMS_PER_PAGE;
		auto offset = lastIndex % NUM_ITEMS_PER_PAGE;

		auto &pageRef = _getPageForWrite(pageIdx);
		--_numItems;
		auto &slot = pageRef->slots[offset];
		if constexpr (WRAP_IN_STORAGE) {
			static_assert(is::relocatable<Item>);
			return slot.relocate();
		} else {
			static_assert(std::is_trivially_copyable_v<Item>);
			return slot;
		}
		// ! Does not free pages
	}

	void maybeShrink() {
		auto numUsedPages = _numItems / NUM_ITEMS_PER_PAGE;
		_pages.setLessNumItems(numUsedPages);
		_pages.maybeShrink();
	}

	// Item popAndMaybeShrink() {
	// 	auto item = pop();
	// 	maybeShrink();
	// 	return item; // hoping for NRVO
	// }

public:
	template <class... MoreOptions>
	using With = Base::template With<MoreOptions...>;

	template <Size NEW_PAGE_SIZE>
	using WithPageSize = With<option::PAGE_SIZE<NEW_PAGE_SIZE>>;

	using WithCopyOnWrite = With<option::COPY_ON_WRITE<true>>;

	template <template <class, auto... EXTENTS> class TTensor>
	using WithTensor = With<option::Tensor<option::tensor::Use<TTensor>>>;
}; // class Custom

