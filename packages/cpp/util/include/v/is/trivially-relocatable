template <class T>
static constexpr auto TriviallyRelocatable = []() constexpr {
	constexpr bool hasMarker = requires { bool(T::IS_TRIVIALLY_RELOCATABLE); };

	if constexpr (hasMarker) {
		return static_cast<bool>(T::IS_TRIVIALLY_RELOCATABLE);
	} else {
		// Fallback for compilers without trivial-relocatability support.
		return std::is_reference_v<T> ||
		       std::is_trivially_copyable_v<T>; // may be incomplete yet
	}
}();

