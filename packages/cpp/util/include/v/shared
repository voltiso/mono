namespace VOLTISO_NAMESPACE::shared {
template <class Options>
  requires concepts::Options<Options>
class Custom;

template <class Options>
  requires concepts::Options<Options>
struct Specializations {
	using Result = shared::Custom<Options>;
};

template <class Item> struct Specializations<Options<option::Item<Item>>> {
	using Result = Shared<Item>;
};

template <class... Args> using GetCustom = Specializations<Args...>::Result;
} // namespace VOLTISO_NAMESPACE::shared

namespace VOLTISO_NAMESPACE::shared::_ {
template <class CanonicalItem, bool CUSTOM_POOL, Size ALIGN>
struct alignas(ALIGN) ControlBlock {
	using Pool = Pool<ControlBlock>;

	CanonicalItem item;
	Size numReferences = 1;

	[[no_unique_address]] std::conditional_t<CUSTOM_POOL, Pool &, Empty> _pool;

	template <class... Args>
	  requires(!CUSTOM_POOL)
	ControlBlock(Args &&...args) : item(std::forward<Args>(args)...) {}

	template <class... Args>
	  requires CUSTOM_POOL
	ControlBlock(Pool &pool, Args &&...args)
	    : item(std::forward<Args>(args)...), _pool(pool) {}

	auto &pool() {
		if constexpr (CUSTOM_POOL) {
			return _pool;
		} else {
			return Singleton<Pool>::ThreadLocal::maybeInitialize();
		}
	}

	void dereference() {
		if (--numReferences == 0) [[unlikely]] {
			using Handle = Pool::Handle;
			pool().erase(Handle(this));
		}
	}
};
} // namespace VOLTISO_NAMESPACE::shared::_

namespace VOLTISO_NAMESPACE::shared {
template <class Options>
  requires concepts::Options<Options>
class Custom
    : public Object<typename Options::template WithDefault<
        option::TRIVIALLY_RELOCATABLE<true>, option::CustomTemplate<GetCustom>,
        option::InputOptions<Options>>> {
	using Base = Object<typename Options::template WithDefault<
	  option::TRIVIALLY_RELOCATABLE<true>, option::CustomTemplate<GetCustom>,
	  option::InputOptions<Options>>>;

	// final self - named it `Shared` for better editor support
	using Shared = GetCustom<Options>;

public:
	using Item = Options::template Get<option::Item>;
	// static_assert(!std::is_class_v<Item> || std::is_final_v<Item>);

	static constexpr Size ALIGN = Options::template GET<option::ALIGN>
	                                ? Options::template GET<option::ALIGN>
	                                : std::max(alignof(void *), alignof(Item));

	using ControlBlock =
	  _::ControlBlock<Item, Options::template GET<option::CUSTOM_POOL>, ALIGN>;

	static_assert(
	  !std::is_reference_v<Item>, "you probably don't want Shared<Item&>");

	using CanonicalItem = std::remove_cv_t<Item>;
	using Pool = Pool<ControlBlock>;

private:
	Pool::Handle _controlBlock = Pool::Handle::INVALID;

	static auto &_pool()
	  requires(!Options::template GET<option::CUSTOM_POOL>)
	{
		return Singleton<Pool>::ThreadLocal::maybeInitialize();
	}

public:
	template <class... Args>
	static Shared create(Args &&...args)
	  requires(!Options::template GET<option::CUSTOM_POOL>)
	{
		return Shared(_pool().insert(std::forward<Args>(args)...), nullptr);
	}

	template <class... Args>
	static Shared create(Pool &pool, Args &&...args)
	  requires(Options::template GET<option::CUSTOM_POOL>)
	{
		return Shared(pool.insert(pool, std::forward<Args>(args)...), nullptr);
	}

	//

	static Shared create(const Item &item)
	  requires(!Options::template GET<option::CUSTOM_POOL>)
	{
		return Shared(_pool().insert(item), nullptr);
	}

	static Shared create(Pool &pool, const Item &item)
	  requires(Options::template GET<option::CUSTOM_POOL>)
	{
		return Shared(pool.insert(pool, item), nullptr);
	}

	//

	static Shared create(Item &&item)
	  requires(!Options::template GET<option::CUSTOM_POOL>)
	{
		return Shared(_pool().insert(std::move(item)), nullptr);
	}

	static Shared create(Pool &pool, Item &&item)
	  requires(Options::template GET<option::CUSTOM_POOL>)
	{
		return Shared(pool.insert(pool, std::move(item)), nullptr);
	}

	//

	~Custom() {
		if (this->_controlBlock) [[likely]] {
			// std::cout << "erase" << std::endl;
			this->_controlBlock->dereference();
		}
	}

private:
	template <class Arg>
	Custom(Arg &&arg, void *_unusedTag) : _controlBlock{std::forward<Arg>(arg)} {}

public:
	Custom() = delete;

public:
	Custom(const Custom &other) : _controlBlock(other._controlBlock) {
		if (other._controlBlock) [[likely]] {
			++other._controlBlock->numReferences;
		}
	}

	// ! no assignment? - Shared is reference-like
	// auto& operator=(const Custom &other) = delete;
	Shared &operator=(const Custom &other) {
		NE(
		  this->_controlBlock,
		  other._controlBlock); // self-assignment forbidden for now
		// if (this->_controlBlock == other._controlBlock) [[unlikely]]
		//   return *this;

		CHECK(this->_controlBlock); // reference-like, must be valid
		// if (this->_controlBlock) [[likely]] {
		this->_controlBlock->dereference();
		// }

		CHECK(other._controlBlock); // reference-like, must be valid
		this->_controlBlock = other._controlBlock;
		// if (other._controlBlock) [[likely]] {
		++other._controlBlock->numReferences;
		// }
		return Base::self();
	}

	Custom(Custom &&other) noexcept : _controlBlock(other._controlBlock) {
		other._controlBlock = handle::INVALID;
	}

	// ! no assignment? - Shared is reference-like
	// Custom &operator=(const Custom &other) = delete;
	Shared &operator=(Custom &&other) noexcept {
		this->_controlBlock->dereference();
		this->_controlBlock = other._controlBlock;
		other._controlBlock = handle::INVALID;
		return Base::self();
	}

public:
	// ! Hmm... maybe use `.target() = ...` instead? So that it's easy to rebind
	// shared refs

	// assign to underlying value
	template <class OtherItem>
	  requires(
	    std::is_assignable_v<Item &, OtherItem> &&
	    // Only check the second condition if OtherItem actually has operator*
	    (!(requires(OtherItem t) {
		    { *t };
	    }) ||
	     !std::is_assignable_v<Item &, decltype(*std::declval<OtherItem>())>))
	Shared &operator=(OtherItem &&other) {
		target() = std::forward<OtherItem>(other);
		return Base::self();
	}

public:
	Item &target() const { return _controlBlock->item; }
	Item &operator*() const { return target(); }
	Item *operator->() const { return &**this; }
	operator Item &() const { return **this; }
	operator Item &&() const { return (Item &&)target(); }

	// non-const -> const
	operator Custom<
	  typename Options::template With<option::Item<const Item>>> &() {
		using NewOptions =
		  typename Options::template With<option::Item<const Item>>;
		return reinterpret_cast<Custom<NewOptions> &>(*this);
	}

	// auto clone() const {
	//   DCHECK(_controlBlock);
	//   using NewSelf = Shared<std::remove_cv_t<Item>>;
	//   if constexpr (has::clone<Item>)
	//     return NewSelf::create(item().clone());
	//   else
	//     return NewSelf::create(item());
	// }

	[[nodiscard]] GetCustom<
	  typename Options::template With<option::Item<const Item>>> &&
	freeze() && {
		using NewOptions =
		  typename Options::template With<option::Item<const Item>>;
		return reinterpret_cast<GetCustom<NewOptions> &&>(*this);
	}

	[[nodiscard]] const GetCustom<
	  typename Options::template With<option::Item<const Item>>> &&
	freeze() const && {
		using NewOptions =
		  typename Options::template With<option::Item<const Item>>;
		return reinterpret_cast<const GetCustom<NewOptions> &&>(*this);
	}

	const Custom<typename Options::template With<option::Item<const Item>>> &
	frozen() const && {
		static_assert(false, "Shared::frozen() works only for lvalue references");
	}

	[[nodiscard]] GetCustom<
	  typename Options::template With<option::Item<const Item>>> &
	frozen() & {
		using NewOptions =
		  typename Options::template With<option::Item<const Item>>;
		return reinterpret_cast<GetCustom<NewOptions> &>(*this);
	}

	[[nodiscard]] const GetCustom<
	  typename Options::template With<option::Item<const Item>>> &
	frozen() const & {
		using NewOptions =
		  typename Options::template With<option::Item<const Item>>;
		return reinterpret_cast<const GetCustom<NewOptions> &>(*this);
	}

public:
	[[nodiscard]] Size numReferences() const noexcept {
		return _controlBlock->numReferences;
	}

public:
	template <class... MoreOptions>
	using With = Base::template With<MoreOptions...>;

	using WithCustomPool = With<option::CUSTOM_POOL<true>>;
	template <Size ALIGN> using WithAlign = With<option::ALIGN<ALIGN>>;
}; // class Custom

