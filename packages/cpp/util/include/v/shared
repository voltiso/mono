#define DEFINE_OPERATOR(op)                                                    \
	template <class T, class Other>                                              \
	auto operator op(const Custom<T> &lhs, Other &&rhs)                          \
	  ->decltype(*lhs op std::forward<Other>(rhs)) {                             \
		return *lhs op std::forward<Other>(rhs);                                   \
	}                                                                            \
                                                                               \
	template <class T, class Other>                                              \
	auto operator op(Other &&lhs, const Custom<T> &rhs)                          \
	  ->decltype(std::forward<Other>(lhs) op * rhs) {                            \
		return std::forward<Other>(lhs) op * rhs;                                  \
	}

DEFINE_OPERATOR(==)
DEFINE_OPERATOR(!=)

DEFINE_OPERATOR(<)
DEFINE_OPERATOR(<=)

DEFINE_OPERATOR(>)
DEFINE_OPERATOR(>=)

DEFINE_OPERATOR(+)
DEFINE_OPERATOR(+=)

DEFINE_OPERATOR(-)
DEFINE_OPERATOR(-=)

DEFINE_OPERATOR(*)
DEFINE_OPERATOR(*=)

DEFINE_OPERATOR(/)
DEFINE_OPERATOR(/=)

DEFINE_OPERATOR(%)
DEFINE_OPERATOR(%=)

DEFINE_OPERATOR(<<)
DEFINE_OPERATOR(<<=)

DEFINE_OPERATOR(>>)
DEFINE_OPERATOR(>>=)

DEFINE_OPERATOR(&)
DEFINE_OPERATOR(&=)

DEFINE_OPERATOR(|)
DEFINE_OPERATOR(|=)

DEFINE_OPERATOR(^)
DEFINE_OPERATOR(^=)

DEFINE_OPERATOR(&&)
DEFINE_OPERATOR(||)

#undef DEFINE_OPERATOR

